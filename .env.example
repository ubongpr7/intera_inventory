# Django
SECRET_KEY=change-me
LOCAL_SERVER=True

# Database
DB_NAME=intera_inventory
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT verification
# Identity service is the only signer. This service verifies with the public key only.
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=/absolute/path/to/jwt_public.pem
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_AUDIENCE=
JWT_ISSUER=
JWT_JWK_URL=

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Optional storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Optional auth redirects
SOCIAL_AUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000

# Cross-service data should arrive through Kafka projections, not HTTP service URLs.

# Note: email settings are still hardcoded in this service's settings.py.
