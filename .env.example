# Django
SECRET_KEY=change-me
DEBUG=True
LOCAL_SERVER=True
ALLOWED_HOSTS=localhost,127.0.0.1,dev.inventory.interaims.com
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER_ENABLED=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Database
DB_NAME=intera_inventory
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432

# JWT verification
# Identity service is the only signer. This service verifies with the public key only.
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=/absolute/path/to/jwt_public.pem
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_AUDIENCE=
JWT_ISSUER=
JWT_JWK_URL=

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Optional storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Optional auth redirects
SOCIAL_AUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000

# Email
EMAIL_BACKEND=django_smtp_ssl.SSLEmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Cross-service data should arrive through Kafka projections, not HTTP service URLs.

# Kafka
KAFKA_SERVICE_NAME=inventory
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CA_FILE=
KAFKA_SSL_CERT_FILE=
KAFKA_SSL_KEY_FILE=
KAFKA_SSL_KEY_PASSWORD=
KAFKA_CONSUMER_GROUP=inventory-consumer
KAFKA_CONSUMER_TOPICS=identity.user,identity.company_profile,identity.membership,catalog.product,catalog.variant,pos.order
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_POLL_INTERVAL=1.0
KAFKA_REQUEST_TIMEOUT_MS=10000
KAFKA_MESSAGE_TIMEOUT_MS=10000
KAFKA_SESSION_TIMEOUT_MS=10000
KAFKA_HEARTBEAT_INTERVAL_MS=3000
KAFKA_PRODUCER_LINGER_MS=5
KAFKA_PRODUCER_ACKS=all
# Keep this false until kafka_reliability migrations have been applied in the target environment.
KAFKA_USE_OUTBOX=false
KAFKA_ENABLE_CONSUMER_IDEMPOTENCY=true
KAFKA_ENABLE_DLQ=true
KAFKA_COMMIT_FAILED_MESSAGES=true
KAFKA_DLQ_SUFFIX=.dlq
KAFKA_OUTBOX_BATCH_SIZE=100
KAFKA_OUTBOX_POLL_INTERVAL=2.0
KAFKA_OUTBOX_RETRY_DELAY_SECONDS=30

# For authenticated brokers, switch KAFKA_SECURITY_PROTOCOL to SASL_PLAINTEXT or SASL_SSL
# and set the SASL/SSL variables above.
